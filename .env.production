# Production (HTTP backend at remote host)
NEXT_PUBLIC_BACKEND_URL=https://api.myapp.com   # replace with real backend URL
BACKEND_DIRECT_CALL=false
BACKEND_FALLBACK=false

# Database
DATABASE_URL=postgresql://user:password@host/database

# AWS credentials (if the backend needs them)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
