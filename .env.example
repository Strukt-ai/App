# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# Backend URL
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# OpenTelemetry / SigNoz (frontend + server)
OTEL_SERVICE_NAME=strukt-frontend
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# SIGNOZ_INGESTION_KEY=your-signoz-ingestion-key
NEXT_PUBLIC_OTEL_SERVICE_NAME=strukt-frontend
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# Optional: regex list for which URLs receive trace headers (comma-separated)
# NEXT_PUBLIC_OTEL_TRACE_HEADER_URLS=.* 

# Observability Showcase URL
NEXT_PUBLIC_OBSERVABILITY_URL=http://localhost:3001

# CORS allowed origins (comma-separated)
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
